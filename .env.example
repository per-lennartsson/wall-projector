# Copy to .env (repo root) and fill in real values. Never commit the real .env.

# Dev (docker-compose.dev.yml) connects to the local `db` service by hostname;
# prod (docker-compose.yml) connects to whatever Postgres container lives on
# the external `postgres` Docker network (see that file).
DATABASE_URL=postgresql://wallprojector:wallprojector@db:5432/wallprojector

NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 48
NEXTAUTH_SECRET=

# docker-compose.dev.yml only
POSTGRES_USER=wallprojector
POSTGRES_PASSWORD=wallprojector
POSTGRES_DB=wallprojector
POSTGRES_PORT=5432
APP_PORT=3000
