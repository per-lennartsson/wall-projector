# Copy to .env and fill in real values. Never commit the real .env.
DATABASE_URL=postgresql+asyncpg://wallprojector:wallprojector@postgres:5432/wallprojector
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
# Set to false when running locally over plain http (e.g. `uvicorn` directly
# against the Vite dev server on :5173) — a Secure cookie is silently dropped
# by the browser over an insecure origin, breaking refresh. Leave unset/true
# for any real deployment behind an HTTPS-terminating proxy.
COOKIE_SECURE=true
